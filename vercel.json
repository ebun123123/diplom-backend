{
  "version": 2,
  "builds": [
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    },
    {
      "src": "config/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 25,
        "memory": 256
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "config/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "config/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "config/wsgi.py"
    }
  ]
}